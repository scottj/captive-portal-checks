{
  "captive_portal_check_urls": [
    {
      "vendor": "Microsoft",
      "os": "Windows",
      "urls": [
        "http://www.msftconnecttest.com/connecttest.txt",
        "https://www.msftconnecttest.com/connecttest.txt",
        "http://ipv6.msftconnecttest.com/connecttest.txt"
      ],
      "expected_response": "Microsoft Connect Test",
      "expect_ssl_error": true
    },
    {
      "vendor": "Apple",
      "os": "macOS / iOS / iPadOS",
      "urls": [
        "http://captive.apple.com/hotspot-detect.html",
        "https://captive.apple.com/hotspot-detect.html"
      ],
      "expected_response": "<HTML><HEAD><TITLE>Success</TITLE></HEAD><BODY>Success</BODY></HTML>",
      "expect_ssl_error": true
    },
    {
      "vendor": "Google",
      "os": "Android / ChromeOS",
      "urls": [
        "http://connectivitycheck.gstatic.com/generate_204",
        "http://connectivitycheck.android.com/generate_204",
        "http://www.gstatic.com/generate_204",
        "https://www.google.com/generate_204",
        "http://play.googleapis.com/generate_204",
        "http://clients1.google.com/generate_204",
        "http://clients3.google.com/generate_204"
      ],
      "expected_response": "HTTP 204 No Content"
    },
    {
      "vendor": "Mozilla",
      "os": "Firefox Browser",
      "urls": [
        "http://detectportal.firefox.com/success.txt",
        "https://detectportal.firefox.com/success.txt"
      ],
      "expected_response": "success"
    },
    {
      "vendor": "Mozilla",
      "os": "Firefox Browser (modern)",
      "urls": [
        "http://detectportal.firefox.com/canonical.html"
      ],
      "expected_response": "meta http-equiv=\"refresh\""
    },
    {
      "vendor": "Ubuntu / Canonical",
      "os": "Ubuntu Linux",
      "urls": [
        "http://connectivity-check.ubuntu.com/"
      ],
      "expected_response": "HTTP 204 No Content"
    },
    {
      "vendor": "KDE",
      "os": "Linux (KDE Plasma)",
      "urls": [
        "http://networkcheck.kde.org/"
      ],
      "expected_response": "OK"
    },
    {
      "vendor": "GNOME / NetworkManager",
      "os": "Linux (GNOME)",
      "urls": [
        "http://nmcheck.gnome.org/check_network_status.txt",
        "http://network-test.debian.org/nm"
      ],
      "expected_response": "NetworkManager is online"
    },
    {
      "vendor": "Fedora",
      "os": "Fedora Linux",
      "urls": [
        "http://fedoraproject.org/static/hotspot.txt"
      ],
      "expected_response": "OK"
    },
    {
      "vendor": "Curl / Generic",
      "os": "Cross-platform",
      "urls": [
        "http://example.com/",
        "http://httpforever.com/"
      ],
      "expected_response": "HTTP 200 OK with page content"
    },
    {
      "vendor": "Huawei",
      "os": "HarmonyOS / EMUI",
      "urls": [
        "http://connectivitycheck.platform.hicloud.com/generate_204"
      ],
      "expected_response": "HTTP 204 No Content"
    },
    {
      "vendor": "Xiaomi / MIUI",
      "os": "MIUI Android",
      "urls": [
        "http://connect.rom.miui.com/generate_204"
      ],
      "expected_response": "HTTP 204 No Content"
    },
    {
      "vendor": "Cloudflare",
      "os": "Cross-platform / WARP",
      "urls": [
        "http://cp.cloudflare.com/",
        "https://cp.cloudflare.com/"
      ],
      "expected_response": "HTTP 204 No Content"
    },
    {
      "vendor": "Microsoft Edge",
      "os": "Edge Browser",
      "urls": [
        "http://edge-http.microsoft.com/captiveportal/generate_204"
      ],
      "expected_response": "HTTP 204 No Content"
